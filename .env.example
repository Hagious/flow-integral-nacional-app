# Copie este arquivo para .env e preencha com suas credenciais do Supabase
# supabase.com → seu projeto → Project Settings → API

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Sem essas variáveis, o sistema funciona em modo local (localStorage)
# Os dados ficam apenas no navegador — ao conectar o Supabase, ficam na nuvem
